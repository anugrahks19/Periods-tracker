{
  "name": "bloom-mobile",
  "version": "1.0.0",
  "description": "Bloom — Period & Wellness Tracker (Mobile App)",
  "main": "index.js",
  "scripts": {
    "build": "shx mkdir -p www && shx cp -r ../css ../js ../index.html ../manifest.json ../sw.js www/",
    "cap:init": "npx -y @capacitor/cli init Bloom com.bloom.tracker --web-dir www",
    "cap:add:android": "npx -y @capacitor/cli add android",
    "cap:add:ios": "npx -y @capacitor/cli add ios",
    "cap:sync": "npm run build && npx -y @capacitor/cli sync",
    "cap:open:android": "npx -y @capacitor/cli open android",
    "cap:open:ios": "npx -y @capacitor/cli open ios",
    "setup": "npm install && npm run cap:init && npm run cap:add:android && npm run cap:sync"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "shx": "^0.4.0"
  }
}
